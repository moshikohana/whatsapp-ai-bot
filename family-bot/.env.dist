# Family Bot — runtime configuration
# This file holds the SHARED app-level credentials (Anthropic, Groq, Google
# OAuth app, Telegram app). Per-user tokens (Google access tokens, Telegram
# sessions, WhatsApp sessions) live separately in data/tenants/<phone>/.

# Anthropic — for Claude chat. Required.
ANTHROPIC_API_KEY=

# Groq — for voice transcription (Whisper). Optional but recommended.
GROQ_API_KEY=

# Google OAuth — used by the installer for Calendar access.
# Each user authorizes their OWN Google account using this same client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
