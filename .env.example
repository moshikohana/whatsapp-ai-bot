# ─────────────────────────────────────────────
#  WhatsApp AI Bot — Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Claude API Key (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Dashboard port (default: 3000)
PORT=3000


# ─── Google Calendar (optional) ───────────────
# To enable calendar integration:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable "Google Calendar API"
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download credentials.json and paste the contents below
# 5. Run: node setup-calendar.js  to get your access token

GOOGLE_CALENDAR_ENABLED=false

# Paste the full JSON from credentials.json here (on one line):
# GOOGLE_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}

# After running setup-calendar.js, paste the token here:
# GOOGLE_TOKEN={"access_token":"...","refresh_token":"...","scope":"https://www.googleapis.com/auth/calendar","token_type":"Bearer","expiry_date":...}
